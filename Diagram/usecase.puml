@startuml BabsMoney
left to right direction
actor Distributeur as D
actor Client as C
rectangle BabsMoney{
    usecase "Créer Wallet" as UC1
    usecase "Faire un retrait" as UC2
    usecase "Faire un dépôt" as UC3
    usecase "Faire un Transfert" as UC4
    usecase "Faire un Paiement" as UC5
    usecase "Consulter l'historique" as UC6
    usecase "S'authentifier" as UC7
}

D --> UC1
D --> UC2
D --> UC3
C --> UC4
C --> UC5
C --> UC6

UC1 ..> UC7 : include
UC2 ..> UC7 : include
UC3 ..> UC7 : include
UC4 ..> UC7 : include
UC5 ..> UC7 : include
UC6 ..> UC7 : include
@enduml